# Telegram Bot API token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace_me

# Your Telegram chat id. Run the bot and send /start to see it.
TELEGRAM_CHAT_ID=123456789

# Gameloft account email used for OTP login.
ASPHALT_EMAIL=you@example.com

# Linux/server default. Use false locally when you want to watch the browser.
HEADLESS=true

# Browser engine. Use firefox as fallback on constrained aarch64/proot Linux if Chromium crashes.
BROWSER_ENGINE=chromium

# Browser identity / compatibility. Defaults are desktop-like and safe for Linux.
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=Europe/Paris
BROWSER_USER_AGENT=

# false = clean user logs. true = stack traces and raw API details.
DEBUG=false

# Temporary PM2 restart notification lifetime.
RESTART_NOTIFICATION_TTL_HOURS=6

# User-facing "program is alive" heartbeat log/dashboard update interval.
HEARTBEAT_INTERVAL_HOURS=6

# Daily Telegram audit interval.
DAILY_AUDIT_INTERVAL_HOURS=24

# Asphalt Legends shop URL.
SHOP_URL=https://shop.gameloft.com/games/Asphalt_Legends

# Storage paths. Relative paths are resolved from project root.
DATA_DIR=./data
BROWSER_PROFILE_DIR=./data/browser-profile
REWARD_IMAGES_DIR=./data/reward-images
DEBUG_SNAPSHOTS_DIR=./data/debug-snapshots
SQLITE_PATH=./data/asphalt.sqlite

# Cleanup retention.
IMAGE_RETENTION_DAYS=3
DEBUG_SNAPSHOT_RETENTION_DAYS=7

# Browser and selector timeouts.
NAVIGATION_TIMEOUT_MS=60000
SELECTOR_TIMEOUT_MS=15000
CLAIM_TIMEOUT_MS=8000

# Optional browser flags for constrained Linux/proot environments.
# Comma-separated, leave empty unless Chromium crashes.
BROWSER_EXTRA_ARGS=

# Optional path to system browser. Useful if Playwright bundled browser crashes on Linux/proot.
BROWSER_EXECUTABLE_PATH=

# Scheduled retry behavior for unavailable rewards.
REWARD_RETRY_COUNT=2
REWARD_RETRY_DELAY_MS=120000

# Safety cap for unexpectedly large Free Gift batches.
MAX_REWARDS_PER_COLLECT=5

# Send a Telegram warning if polling cannot recover for this long.
TELEGRAM_POLLING_ALERT_AFTER_MS=300000
